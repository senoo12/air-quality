---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pengaturan">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl font-bold mb-8">Pengaturan</h1>
        
        <div class="bg-gray-800 border border-gray-700 rounded-2xl p-6">
            <h2 class="text-xl font-semibold mb-4 text-red-400">Akun & Sesi</h2>
            <p class="text-gray-400 mb-6">Keluar dari sistem akan menghapus sesi login di browser ini.</p>
            
            <button id="logoutBtn" class="bg-red-600/20 text-red-500 border border-red-600/50 hover:bg-red-600 hover:text-white px-6 py-2 rounded-xl transition-all">
                Keluar (Logout)
            </button>
        </div>
    </div>

    <script>
        document.getElementById('logoutBtn').addEventListener('click', () => {
            if (confirm('Apakah anda yakin ingin keluar?')) {
                localStorage.removeItem('token');
                window.location.href = '/login';
            }
        });
    </script>
</Layout>